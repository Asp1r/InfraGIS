[Unit]
Description=InfraGIS automatic update and deploy
Wants=network-online.target
After=network-online.target docker.service

[Service]
Type=oneshot
User=infragis
WorkingDirectory=/home/infragis
Environment=PROJECT_DIR=/home/infragis
Environment=BRANCH=master
Environment=HEALTH_URL=http://127.0.0.1/health
Environment=COMPOSE_FILE=docker-compose.prod.yml
ExecStart=/usr/bin/bash /home/infragis/scripts/auto-update.sh
TimeoutStartSec=900

[Install]
WantedBy=multi-user.target
